{
	"cli": {
		"version": ">= 16.7.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"channel": "development"
		},
		"ios-simulator": {
			"extends": "development",
			"ios": {
				"simulator": true
			},
			"environment": "development",
			"channel": "ios-simulator"
		},
		"preview": {
			"distribution": "internal",
			"autoIncrement": true,
			"channel": "preview"
		},
		"production": {
			"autoIncrement": true,
			"channel": "production"
		}
	},
	"submit": {
		"production": {}
	}
}
